// ==UserScript==
// @name         ChatGPT 浏览器搜索串辅助脚本
// @namespace    http://tampermonkey.net/
// @version      1.0
// @description  解析 URL 中的 q 参数，自动填入 ChatGPT 并发送
// @author       YourName
// @match        https://chatgpt.com/*
// @grant        none
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    const urlParams = new URLSearchParams(window.location.search);
    const query = urlParams.get('q');

    if (query) {
        const searchText = decodeURIComponent(query);

        // 每 200ms 轮询一次，等待 ChatGPT 输入框加载完成
        const checkExist = setInterval(function() {
            // ChatGPT 的输入框通常是一个带有 id="prompt-textarea" 的 div
            const editor = document.querySelector('#prompt-textarea');

            if (editor) {
                clearInterval(checkExist);

                // 1. 聚焦到输入框
                editor.focus();

                // 2. 清空既有内容（防止残留），并填入新文本
                // ChatGPT 是富文本，内部文字一般包裹在 <p> 中
                let p = editor.querySelector('p');
                if (!p) {
                    p = document.createElement('p');
                    editor.appendChild(p);
                }
                p.textContent = searchText;

                // 3. 核心：强行触发 input 事件，让 React 监听到内容变化并激活发送按钮
                editor.dispatchEvent(new Event('input', { bubbles: true }));

                // 4. 延迟等待 DOM 状态更新与发送按钮启用
                setTimeout(() => {
                    // 方案 A：通过 data-testid 准确定位发送按钮（OpenAI 官方常用的测试属性）
                    // 同时兼容旧版的 send-button 属性或 aria-label
                    const sendButton = document.querySelector('[data-testid="send-button"]') ||
                                       document.querySelector('button[aria-label*="发送"], button[aria-label*="Send"]');

                    if (sendButton && !sendButton.disabled) {
                        sendButton.click();
                    } else {
                        // 方案 B：如果按钮不可点击或未找到，尝试直接模拟按下 Enter 键
                        const enterEvent = new KeyboardEvent('keydown', {
                            bubbles: true,
                            cancelable: true,
                            key: 'Enter',
                            code: 'Enter',
                            keyCode: 13,
                            which: 13
                        });
                        editor.dispatchEvent(enterEvent);
                    }
                }, 400);
            }
        }, 200);
    }
})();
